# =================================================================
# ALM Distribuidora — Variáveis de ambiente (template)
# Copie este arquivo para .env e preencha os valores
# =================================================================

# Banco de dados
# - DEV LOCAL:    "file:./dev.db"  (SQLite, padrão)
# - PRODUCAO:     "postgresql://USER:PASS@HOST/DB?sslmode=require"
DATABASE_URL="file:./dev.db"

# Segredo da sessão (gere um valor aleatório em produção)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="troque-por-um-segredo-aleatorio-de-32-caracteres"
